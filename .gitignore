# Unity packages lock (keep the lockfile!)
# Packages/packages-lock.json  <-- DO NOT ignore (kept by default)

# Addressables cache
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Asset meta handling:
# Keep .meta files (Unity needs them)
!*.meta

# IL2CPP / Burst / Bee
[Bb]urstDebugInformation_DoNotShip*/
[Bb]urstDebugInformation*/
[Bb]ee/
[Bb]ee~/
.il2cpp/

# Crash reports
sysinfo.txt

# Visual Studio / Rider / MonoDevelop caches
*.unitypackage
*.apk
*.aab

# JetBrains Rider plugin for Unity
Assets/Plugins/Editor/JetBrains*

# Unity Collab / PlasticSCM (if used)
.plastic/
.plasticignore
.vscode-Unity/

# Cursor / local tooling (safe to ignore)
.cursor/
**/.cursor/

# Imported asset packs (ignore entire folders)
Assets/Sci-Fi Small Sound Pack/**
Assets/SwordSoundPack/**
Assets/Casual Game Sounds U6/**
Assets/Inguz Media Studio/**
Assets/Leohpaz/**
Assets/Martial Hero/**
Assets/Super Grotto Escape/**
Assets/Warped City Assets/**

# If you also want to ignore the sample template:
Assets/Simple 2D Platformer BE2/**

# Keep everything else in Assets/ under version control